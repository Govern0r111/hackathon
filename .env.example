# Copy to .env and fill in if you want to use Vertex AI
# NOTE: Vertex AI typically uses Google Cloud auth (ADC / service accounts), not an API key.
VERTEX_PROJECT=
VERTEX_LOCATION=us-central1
VERTEX_MODEL=

# Local auth option (recommended for dev):
# - Either run: gcloud auth application-default login
# - Or point to a service account JSON file:
GOOGLE_APPLICATION_CREDENTIALS=

# Optional
APP_ENV=dev
